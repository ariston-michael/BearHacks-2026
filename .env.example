# Copy this file to .env.local and fill in real values.
# Variables prefixed RENDERER_VITE_ are exposed to the renderer via import.meta.env.

# ElevenLabs Scribe (speech-to-text) API key.
# Get one at https://elevenlabs.io/app/speech-to-text
RENDERER_VITE_ELEVENLABS_API_KEY=

# Vultr Serverless Inference API key.
# Get from: Vultr Dashboard -> Serverless Inference -> your subscription -> API Key
RENDERER_VITE_VULTR_INFERENCE_KEY=
